{
  "routes": [
    {
      "route": "/all-projects",
      "rewrite": "/index.html"
    },
    {
      "route": "/gallery",
      "rewrite": "/index.html"
    },
    {
      "route": "/clients",
      "rewrite": "/index.html"
    },
    {
      "route": "/badges",
      "rewrite": "/index.html"
    },
    {
      "route": "/github",
      "rewrite": "/index.html"
    },
    {
      "route": "/coding",
      "rewrite": "/index.html"
    },
    {
      "route": "/*",
      "serve": "/index.html",
      "statusCode": 200
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/images/*.{png,jpg,gif}", "/css/*", "/js/*", "/assets/*"]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  },
  "platform": {
    "apiRuntime": "node:18"
  }
}
