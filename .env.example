# Google Analytics Measurement ID (GA4)
# To get your Measurement ID:
# 1. Go to https://analytics.google.com/
# 2. Sign in with your Google account
# 3. Create a new property or select an existing one
# 4. Go to Admin > Property > Data Streams
# 5. Select your data stream or create one
# 6. Copy the Measurement ID (format: G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Example:
# VITE_GA_MEASUREMENT_ID=G-ABC123DEF45

# ==========================================
# Google AdSense Configuration
# ==========================================
# To set up Google AdSense:
# 1. Go to https://www.google.com/adsense/
# 2. Sign up and get your account approved
# 3. Get your Publisher ID (ca-pub-XXXXXXXXXXXXXXXX)
# 4. Create Ad Units and get their Slot IDs

# Your Google AdSense Publisher ID
VITE_ADSENSE_PUBLISHER_ID=ca-pub-REPLACE_WITH_YOUR_ID

# Ad Slot IDs (create these in your AdSense dashboard)
VITE_ADSENSE_SLOT_TOP=REPLACE_WITH_TOP_SLOT_ID
VITE_ADSENSE_SLOT_MIDDLE=REPLACE_WITH_MIDDLE_SLOT_ID
VITE_ADSENSE_SLOT_BOTTOM=REPLACE_WITH_BOTTOM_SLOT_ID

# Example:
# VITE_ADSENSE_PUBLISHER_ID=ca-pub-1234567890123456
# VITE_ADSENSE_SLOT_TOP=1234567890
# VITE_ADSENSE_SLOT_MIDDLE=2345678901
# VITE_ADSENSE_SLOT_BOTTOM=3456789012